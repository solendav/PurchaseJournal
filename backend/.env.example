NODE_ENV=development
PORT=5003
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=purchase_journal
DB_USER=postgres
DB_PASSWORD=postgres

JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=15m
UPLOAD_DIR=uploads

# Email verification (set SMTP_* in production)
REQUIRE_EMAIL_VERIFICATION=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Purchase Journal <noreply@localhost>
