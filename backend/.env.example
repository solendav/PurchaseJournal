NODE_ENV=development
PORT=5003
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production (Vercel): set DATABASE_URL instead of DB_* below
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=purchase_journal
DB_USER=postgres
DB_PASSWORD=postgres
PG_SSL=false

JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=15m
APP_PUBLIC_URL=http://localhost:5003
UPLOAD_DIR=uploads

# Email verification (set SMTP_* in production)
REQUIRE_EMAIL_VERIFICATION=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Purchase Journal <noreply@localhost>

# Receipt uploads on Vercel (required in production serverless)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=purchase-journal
