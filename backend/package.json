{
  "name": "purchase-journal-backend",
  "version": "1.0.0",
  "description": "Backend API for Purchase Journal — supplier purchase records with receipt images",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "db:setup": "node src/db/setup.js",
    "db:setup:clean": "node src/db/setup.js --clean --force",
    "db:seed": "node src/db/seed.js",
    "db:migrate": "node src/db/migrate.js",
    "db:reset": "node src/db/setup.js --clean --force && node src/db/seed.js"
  },
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.2",
    "nodemailer": "^6.10.1",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-http": "^10.2.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
